# Supabase credentials (optional - currently hardcoded in src/lib/supabase.js)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Version control (set in each Vercel deployment)
# V1 deployment: leave unset or set to "v1"
# V2 deployment: set to "v2"
VITE_APP_VERSION=v2

# URLs shown in admin dashboard version switcher
VITE_V1_URL=https://lunaloop.app
VITE_V2_URL=https://v2.lunaloop.app
